# Copy to .env and edit. The defaults run fully offline with no keys.

# Embedding backend: hash (default, offline) | openai | huggingface
EMBED_BACKEND=hash

# Retrieval and chunking knobs (tune in Lab 7.3)
TOP_K=4
CHUNK_SIZE=384
CHUNK_OVERLAP=64

# Only needed if EMBED_BACKEND=openai or you wire a generation LLM
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
