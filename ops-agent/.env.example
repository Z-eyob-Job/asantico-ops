# Copy to .env. The CLI demo runs with none of these set.

# LLM router + grounded answer generation (production).
# The key is read from the environment only; it is never logged or written to disk.
# ANTHROPIC_API_KEY=sk-ant-...

# Router backend: "keyword" (default, deterministic, zero deps, no key) or "llm"
# for the Anthropic function-calling router. If "llm" is selected but no key /
# SDK is available or the call fails, the router logs a warning and falls back to
# keyword routing. The policy gate stops gated actions regardless of the router.
# ROUTER_BACKEND=llm

# Model for the LLM router and grounded answers (default claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Grounded knowledge_base answers: "auto" (default) generates a short answer from
# the retrieved sources when a key is present; set to 0/off to always return the
# raw retrieved snippets. Sources are returned either way.
# KB_GROUNDED=auto

# Telegram channel (recommended first real channel)
# TELEGRAM_BOT_TOKEN=...

# Email channel
# EMAIL_USER=you@example.com
# EMAIL_PASS=app-password-here

# WhatsApp (hardest; add last)
# WHATSAPP_TOKEN=...
# WHATSAPP_PHONE_ID=...

KNOWLEDGE_DIR=knowledge

# knowledge_base retrieval backend: "offline" (default, zero deps, hash retrieval)
# or "rag" for the real knowledge-rag LlamaIndex pipeline. If "rag" is selected but
# llama-index / the pipeline is unavailable, the tool logs a warning and falls back
# to offline. Point KB_RAG_ROOT at the knowledge-rag checkout if it is not the
# sibling directory.
# KB_BACKEND=rag
# KB_RAG_ROOT=../knowledge-rag
