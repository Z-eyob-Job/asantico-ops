# Copy to .env. The CLI demo runs with none of these set.

# LLM router + generation (production)
# ANTHROPIC_API_KEY=sk-ant-...

# Telegram channel (recommended first real channel)
# TELEGRAM_BOT_TOKEN=...

# Email channel
# EMAIL_USER=you@example.com
# EMAIL_PASS=app-password-here

# WhatsApp (hardest; add last)
# WHATSAPP_TOKEN=...
# WHATSAPP_PHONE_ID=...

KNOWLEDGE_DIR=knowledge

# knowledge_base retrieval backend: "offline" (default, zero deps, hash retrieval)
# or "rag" for the real knowledge-rag LlamaIndex pipeline. If "rag" is selected but
# llama-index / the pipeline is unavailable, the tool logs a warning and falls back
# to offline. Point KB_RAG_ROOT at the knowledge-rag checkout if it is not the
# sibling directory.
# KB_BACKEND=rag
# KB_RAG_ROOT=../knowledge-rag
